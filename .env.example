# Redis — usado só para dedup (evitar postar a mesma promoção repetidas vezes).
# Sem isso configurado, o worker funciona mas sem dedup (pode repetir post a cada checagem).
REDIS_URL=

# Intervalo entre checagens, em minutos (só usado em "npm start", não no GitHub Actions).
CHECK_INTERVAL_MINUTES=30

# % mínimo de desconto pra considerar uma promoção relevante e enviar no WhatsApp.
DEAL_DISCOUNT_THRESHOLD=40

# Janela de repost: após X horas a mesma promoção pode ser postada de novo.
# Maior = menos repetição, prioriza links novos/distintos (24 = no máx. 1x/dia).
DEDUP_TTL_HOURS=24
# Máximo de posts por fonte por execução.
MAX_POSTS_PER_RUN=10

# Quais fontes monitorar (separadas por vírgula): amazon, lomadee
ACTIVE_SOURCES=amazon,lomadee,docebeleza
# Quantidade de buscas da Amazon por execução. Cinco mantém o piloto rápido.
AMAZON_SEARCH_SEED_LIMIT=5

# Palavras-chave EXTRAS além das já embutidas no código (limpeza, bem-estar, cosméticos).
# Separadas por vírgula. Vazio = usar só as keywords base. Exemplo: brinquedo,eletronico
CATEGORY_KEYWORDS=

# Tag do Amazon Associates.
AMAZON_AFFILIATE_TAG=
# Lomadee — chave de API (header x-api-key). lmd_dev_ = sandbox; use lmd_prod_ em produção.
LOMADEE_API_KEY=
# Opcional: IDs de organização (marcas) para restringir ao seu nicho, separados por vírgula.
LOMADEE_ORGANIZATION_IDS=

# Awin — Publisher ID (usado no deep link da fonte docebeleza). Token da API opcional.
AWIN_PUBLISHER_ID=
AWIN_API_TOKEN=

# Provedor: baileys (piloto local) ou meta (Cloud API oficial).
WHATSAPP_PROVIDER=baileys

# Baileys. Remetente no formato internacional, somente dígitos.
BAILEYS_PHONE_NUMBER=5511999999999
BAILEYS_AUTH_DIR=.baileys-auth
BAILEYS_PAIRING_METHOD=qr
BAILEYS_GROUP_NAME=Promoções Amazon
# Intervalo mínimo entre destinatários. Valores abaixo de 1000 são ignorados.
BAILEYS_SEND_DELAY_MS=3000

# Destinatários: números internacionais separados por vírgula. Grupos aceitam o JID terminado em @g.us.
WHATSAPP_RECIPIENTS=5511999999999

# WhatsApp Cloud API (Meta), usada somente quando WHATSAPP_PROVIDER=meta.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=promocao_afiliado
WHATSAPP_TEMPLATE_LANGUAGE=pt_BR
# Opcional. Permite atualizar a versão da Graph API sem alterar o código.
WHATSAPP_API_VERSION=v25.0
