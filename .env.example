# Redis — usado só para dedup (evitar postar a mesma promoção repetidas vezes).
# Sem isso configurado, o worker funciona mas sem dedup (pode repetir post a cada checagem).
REDIS_URL=

# Intervalo entre checagens, em minutos (só usado em "npm start", não no GitHub Actions).
CHECK_INTERVAL_MINUTES=30

# % mínimo de desconto pra considerar uma promoção relevante e postar no Telegram.
DEAL_DISCOUNT_THRESHOLD=40

# Quais fontes monitorar (separadas por vírgula): amazon, mercadolivre
ACTIVE_SOURCES=amazon,mercadolivre

# Filtro por palavra-chave no título (separadas por vírgula). Vazio = sem filtro, todas as categorias.
CATEGORY_KEYWORDS=limpeza,detergente,sabao,sabonete,cosmetico,shampoo,condicionador,perfume,creme,hidratante,maquiagem,higiene

# Tags/códigos de afiliado — preencher quando aprovado em cada programa.
AMAZON_AFFILIATE_TAG=
# Mercado Livre — EXPERIMENTAL, ver comentário em src/lib/deals/affiliate.ts.
MERCADOLIVRE_AFFILIATE_TAG=
MERCADOLIVRE_MATT_TOOL=

# Bot do Telegram — token via @BotFather, chat ID do grupo (negativo).
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
