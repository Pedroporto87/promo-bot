# Redis — usado só para dedup (evitar postar a mesma promoção repetidas vezes).
# Sem isso configurado, o worker funciona mas sem dedup (pode repetir post a cada checagem).
REDIS_URL=

# Intervalo entre checagens, em minutos (só usado em "npm start", não no GitHub Actions).
CHECK_INTERVAL_MINUTES=30

# % mínimo de desconto pra considerar uma promoção relevante e postar no Telegram.
DEAL_DISCOUNT_THRESHOLD=40

# Quais fontes monitorar (separadas por vírgula): amazon, lomadee
ACTIVE_SOURCES=amazon,lomadee

# Palavras-chave EXTRAS além das já embutidas no código (limpeza, bem-estar, cosméticos).
# Separadas por vírgula. Vazio = usar só as keywords base. Exemplo: brinquedo,eletronico
CATEGORY_KEYWORDS=

# Tag do Amazon Associates.
AMAZON_AFFILIATE_TAG=
# Lomadee — chave de API (header x-api-key). lmd_dev_ = sandbox; use lmd_prod_ em produção.
LOMADEE_API_KEY=
# Opcional: IDs de organização (marcas) para restringir ao seu nicho, separados por vírgula.
LOMADEE_ORGANIZATION_IDS=

# Bot do Telegram — token via @BotFather, chat ID do grupo (negativo).
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
